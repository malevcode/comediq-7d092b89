# Supabase (Comediq2.0 — auth + database)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Public browser token used only for Mapbox map rendering.
# Restrict this token in Mapbox to comediq.us and localhost.
VITE_MAPBOX_TOKEN=your_public_mapbox_token

SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe Payment Link (create in Stripe Dashboard → Payment Links)
# Full Pass: $20/month
VITE_STRIPE_PAID_LINK=https://buy.stripe.com/your_paid_link

# Stripe Edge Function secrets — set via: supabase secrets set KEY=value
# For temporary local testing, put these in .env.local and run:
# supabase functions serve --env-file .env.local
# Then point the browser app at local functions:
# VITE_SUPABASE_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1
# STRIPE_SECRET_KEY=sk_live_...
# SNAPSHOT_STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PAID=price_...
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SITE_URL=https://comediq.us
